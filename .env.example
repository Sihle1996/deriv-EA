# Copy this file to ".env" and fill in your DEMO token.
#
# 1. Log in to Deriv and switch to a VIRTUAL (demo) account.
# 2. Create a token at https://app.deriv.com/account/api-token
#    Scopes: Read + Trade (Trade is not used in Phase 1, but keeps the token ready for later).
# 3. Paste it below. Phase 1 HARD-BLOCKS real-money accounts, so a demo token is required.

DERIV_API_TOKEN=

# app_id 1089 is Deriv's public testing app_id. Register your own at https://api.deriv.com
# before going to production, but 1089 is fine for demo development.
DERIV_APP_ID=1089

# Default market. stpRNG = Step Index. main.py prints all "step"-matching symbols on startup
# so you can confirm the exact code rather than trusting this default.
DERIV_SYMBOL=stpRNG
